// prisma/schema.prisma

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Enums ─────────────────────────────────────────────────────────────────────

enum GameMode {
  standard
  pauper
  royal
}

enum TournamentFormat {
  single_elimination
  swiss
  round_robin
  arena
}

enum TournamentStatus {
  upcoming
  active
  finished
  cancelled
}

// ─── Admin ─────────────────────────────────────────────────────────────────────
// Completely separate from the player User table.
// Admins are created manually via seed script — no signup flow.

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([username])
}

// ─── User ──────────────────────────────────────────────────────────────────────

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Per-mode ELO
  eloStandard         Int @default(1200)
  eloPauper           Int @default(1200)
  eloRoyal            Int @default(1200)
  gamesPlayedStandard Int @default(0)
  gamesPlayedPauper   Int @default(0)
  gamesPlayedRoyal    Int @default(0)
  winsStandard        Int @default(0)
  winsPauper          Int @default(0)
  winsRoyal           Int @default(0)
  lossesStandard      Int @default(0)
  lossesPauper        Int @default(0)
  lossesRoyal         Int @default(0)
  drawsStandard       Int @default(0)
  drawsPauper         Int @default(0)
  drawsRoyal          Int @default(0)

  // Queue & game state
  queueStatus   String?   @default("offline")
  queuedAt      DateTime?
  queuedDraftId Int?
  queuedMode    GameMode?

  // Stripe
  stripeCustomerId String? @unique

  // Admin and moderation
  isAdmin      Boolean   @default(false)
  isBanned     Boolean   @default(false)
  bannedAt     DateTime?
  bannedReason String?

  // Email verification
  emailVerificationToken          String?   @unique
  emailVerificationTokenExpiresAt DateTime?

  // Password reset
  passwordResetToken          String?   @unique
  passwordResetTokenExpiresAt DateTime?

  // Relations
  drafts             Draft[]
  queuedDraft        Draft?             @relation("UserQueuedDraft", fields: [queuedDraftId], references: [id], onDelete: SetNull)
  gamesAsPlayer1     Game[]             @relation("Player1")
  gamesAsPlayer2     Game[]             @relation("Player2")
  gamesAsWhite       Game[]             @relation("WhitePlayer")
  tokens             UserToken[]
  notifications      Notification[]
  tournamentEntries  TournamentPlayer[]
  following          UserFollow[]       @relation("Follower")
  followers          UserFollow[]       @relation("Following")
  sentRequests       FriendRequest[]    @relation("SentRequests")
  receivedRequests   FriendRequest[]    @relation("ReceivedRequests")
  sentChallenges     GameChallenge[]    @relation("SentChallenges")
  receivedChallenges GameChallenge[]    @relation("ReceivedChallenges")
  accounts           Account[]
  sessions           Session[]

  @@index([queueStatus])
  @@index([queuedDraftId])
  @@index([eloStandard])
  @@index([eloPauper])
  @@index([eloRoyal])
  @@index([isBanned])
  @@index([isAdmin])
  @@index([stripeCustomerId])
}

// ─── Draft ─────────────────────────────────────────────────────────────────────

model Draft {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String?
  fen       String
  points    Int
  mode      GameMode @default(standard)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  queuedByUsers User[]          @relation("UserQueuedDraft")
  gamesAsDraft1 Game[]          @relation("GameDraft1")
  gamesAsDraft2 Game[]          @relation("GameDraft2")
  challenges    GameChallenge[] @relation("ChallengeSenderDraft")

  @@index([userId])
  @@index([userId, mode])
  @@index([updatedAt])
}

// ─── Game ──────────────────────────────────────────────────────────────────────

model Game {
  id            Int      @id @default(autoincrement())
  player1Id     Int
  player2Id     Int
  whitePlayerId Int
  mode          GameMode @default(standard)
  status        String   @default("waiting")
  draft1Id      Int?
  draft2Id      Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  fen           String?
  prepStartedAt DateTime?
  readyPlayer1  Boolean  @default(false)
  readyPlayer2  Boolean  @default(false)
  auxPointsPlayer1 Int @default(6)
  auxPointsPlayer2 Int @default(6)

  lastMoveAt      DateTime?
  lastMoveBy      Int?
  moveNumber      Int       @default(0)
  player1Timebank Int       @default(60000)
  player2Timebank Int       @default(60000)

  winnerId         Int?
  player1EloBefore Int?
  player2EloBefore Int?
  player1EloAfter  Int?
  player2EloAfter  Int?
  eloChange        Int?
  endReason        String?
  isFriendGame     Boolean @default(false)

  pgn String? @db.Text

  rematchRequestedBy Int?

  tournamentId    Int?
  tournamentRoundId Int?

  player1    User        @relation("Player1",     fields: [player1Id],     references: [id], onDelete: Cascade)
  player2    User        @relation("Player2",     fields: [player2Id],     references: [id], onDelete: Cascade)
  whitePlayer User       @relation("WhitePlayer", fields: [whitePlayerId], references: [id], onDelete: Cascade)
  draft1     Draft?      @relation("GameDraft1",  fields: [draft1Id],      references: [id], onDelete: SetNull)
  draft2     Draft?      @relation("GameDraft2",  fields: [draft2Id],      references: [id], onDelete: SetNull)
  tournament      Tournament?      @relation(fields: [tournamentId],      references: [id], onDelete: SetNull)
  tournamentRound TournamentRound? @relation("GameTournamentRound", fields: [tournamentRoundId], references: [id], onDelete: SetNull)
  tournamentGame  TournamentGame?
  moves      Move[]

  @@index([player1Id])
  @@index([player2Id])
  @@index([whitePlayerId])
  @@index([status])
  @@index([mode])
  @@index([createdAt])
  @@index([draft1Id])
  @@index([draft2Id])
  @@index([winnerId])
  @@index([lastMoveAt])
  @@index([tournamentId])
  @@index([tournamentRoundId])
  @@index([status, lastMoveAt])
  @@index([player1Id, mode, createdAt])
  @@index([player2Id, mode, createdAt])
}

// ─── Move ──────────────────────────────────────────────────────────────────────

model Move {
  id         Int    @id @default(autoincrement())
  gameId     Int
  moveNumber Int
  from       String
  to         String
  promotion  String?
  san        String
  fen        String
  createdAt  DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, moveNumber])
  @@index([gameId])
}

// ─── Tokens ────────────────────────────────────────────────────────────────────

model TokenDefinition {
  id          Int     @id @default(autoincrement())
  slug        String  @unique
  label       String
  description String?
  icon        String? // emoji or short symbol e.g. "👑", "★"
  color       String? // hex color for badge tint e.g. "#f59e0b"
  adminOnly   Boolean @default(true)
  durationDays Int?   // null = permanent, N = expires after N days

  // Whether holding this token grants specific app privileges.
  grantsPrivilege Boolean @default(false)

  // Purchasable tokens (wired to Stripe at step 4)
  isPurchasable Boolean @default(false)
  stripePriceId String? @unique // Stripe Price ID e.g. "price_xxx"

  // Whether this token is consumed when used for tournament entry.
  // false = checked for presence only (e.g. premium token)
  // true  = deducted on entry (e.g. qualifier token)
  consumeOnEntry Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  holders UserToken[]

  @@index([slug])
  @@index([grantsPrivilege])
  @@index([isPurchasable])
}

model UserToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  tokenId   Int
  grantedAt DateTime @default(now())
  grantedBy Int?     // adminUser.id of admin who granted, null if auto-granted or purchased

  // Expiry — null means permanent (achievement tokens, lifetime purchases)
  expiresAt DateTime?

  // Status: active | expired | revoked
  status String @default("active")

  // Payment tracking (null for non-purchased tokens)
  stripePaymentIntentId String?

  note String?

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  token TokenDefinition @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@unique([userId, tokenId])
  @@index([userId])
  @@index([tokenId])
  @@index([expiresAt])
  @@index([status])
  @@index([userId, status])
}

// ─── Stripe ────────────────────────────────────────────────────────────────────

model StripeWebhookEvent {
  id        String   @id // Stripe event ID (evt_...)
  type      String
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([processed])
}

// ─── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String
  payload   Json
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─── Tournament ────────────────────────────────────────────────────────────────

model Tournament {
  id                 Int              @id @default(autoincrement())
  name               String
  description        String?          @db.Text
  mode               GameMode         @default(standard)
  format             TournamentFormat @default(single_elimination)
  status             TournamentStatus @default(upcoming)
  registrationEndsAt DateTime?
  startsAt           DateTime?
  finishedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  maxPlayers         Int?
  minPlayers         Int              @default(2)
  prizeDescription   String?
  winnerId           Int?

  requiredTokenSlug String?

  stages TournamentStage[]
  prizes TournamentPrize[]

  players TournamentPlayer[]
  games   Game[]

  @@index([status])
  @@index([mode])
  @@index([startsAt])
  @@index([requiredTokenSlug])
}

model TournamentPlayer {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  userId       Int
  registeredAt DateTime @default(now())
  score        Float    @default(0)
  rank         Int?
  buchholz     Float    @default(0)
  eliminated   Boolean  @default(false)

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
  @@index([tournamentId, score])
}

model TournamentStage {
  id           Int      @id @default(autoincrement())
  tournamentId Int
  stageNumber  Int
  name         String?

  format TournamentFormat

  // null on the final stage — runs until a full hierarchy is determined
  advanceCount Int?

  // "fixed"    → fixedStartAt is used
  // "relative" → starts relativeBreakMinutes after previous stage ends
  startTimeType        String    @default("fixed")
  fixedStartAt         DateTime?
  relativeBreakMinutes Int?

  // For swiss: explicit round count. null = ceil(log2(playerCount))
  totalRounds  Int?
  currentRound Int      @default(0)

  // "pending" | "active" | "paused" | "finished"
  status     String    @default("pending")
  startedAt  DateTime?
  finishedAt DateTime?

  tournament  Tournament                 @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  rounds      TournamentRound[]
  placements  TournamentStagePlacement[]

  @@unique([tournamentId, stageNumber])
  @@index([tournamentId])
  @@index([status])
}

model TournamentRound {
  id          Int      @id @default(autoincrement())
  stageId     Int
  roundNumber Int

  draftPickDeadline DateTime?

  // "awaiting_drafts" | "active" | "finished"
  status     String    @default("awaiting_drafts")
  startedAt  DateTime?
  finishedAt DateTime?

  stage     TournamentStage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  games     TournamentGame[]
  liveGames Game[]           @relation("GameTournamentRound")

  @@unique([stageId, roundNumber])
  @@index([stageId])
  @@index([status])
}

model TournamentGame {
  id      Int  @id @default(autoincrement())
  roundId Int
  gameId  Int? @unique

  player1Id Int
  player2Id Int

  // Populated during the 3-minute pick window or auto-assigned at deadline
  player1DraftId Int?
  player2DraftId Int?

  isBye    Boolean @default(false)
  winnerId Int?
  isDraw   Boolean @default(false)

  round TournamentRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  game  Game?           @relation(fields: [gameId],  references: [id], onDelete: SetNull)

  @@index([roundId])
  @@index([gameId])
  @@index([player1Id])
  @@index([player2Id])
}

model TournamentStagePlacement {
  id        Int     @id @default(autoincrement())
  stageId   Int
  userId    Int
  rank      Int
  rankLabel String? // null for top-4 individual, "5–8" etc. beyond that

  stage TournamentStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([stageId, userId])
  @@index([stageId])
}

model TournamentPrize {
  id           Int     @id @default(autoincrement())
  tournamentId Int
  rankFrom     Int
  rankTo       Int
  prizeType    String  @default("token") // "token" | "other"
  tokenSlug    String?
  description  String?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
}

// ─── Friends / Follow ──────────────────────────────────────────────────────────

model UserFollow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())

  follower  User @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model FriendRequest {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("SentRequests",     fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([receiverId, status])
}

// ─── Game Challenges ───────────────────────────────────────────────────────────

model GameChallenge {
  id            Int      @id @default(autoincrement())
  senderId      Int
  receiverId    Int
  mode          GameMode @default(standard)
  senderDraftId Int?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  sender      User   @relation("SentChallenges",       fields: [senderId],      references: [id], onDelete: Cascade)
  receiver    User   @relation("ReceivedChallenges",   fields: [receiverId],    references: [id], onDelete: Cascade)
  senderDraft Draft? @relation("ChallengeSenderDraft", fields: [senderDraftId], references: [id], onDelete: SetNull)

  @@index([senderId])
  @@index([receiverId])
  @@index([receiverId, status])
  @@index([expiresAt])
}

// ─── Auth ──────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

