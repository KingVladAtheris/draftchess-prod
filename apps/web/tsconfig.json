{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target":                   "ES2017",
    "lib":                      ["dom", "dom.iterable", "esnext"],
    "module":                   "esnext",
    "moduleResolution":         "bundler",
    "jsx":                      "preserve",
    "incremental":              true,
    "noUncheckedIndexedAccess": false,
    "noImplicitAny":            false,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*":                              ["./src/*"],
      "@draftchess/db":                   ["../../packages/db/src/index.ts"],
      "@draftchess/shared":               ["../../packages/shared/src/index.ts"],
      "@draftchess/shared/*":             ["../../packages/shared/src/*.ts"],
      "@draftchess/socket-types":         ["../../packages/socket-types/src/index.ts"],
      "@draftchess/logger":               ["../../packages/logger/src/index.ts"],
      "@draftchess/game-state":           ["../../packages/game-state/src/index.ts"],
      "@draftchess/token-service":        ["../../packages/token-service/src/index.ts"],
      "@draftchess/tournament-engine":    ["../../packages/tournament-engine/src/index.ts"],
      "@draftchess/tournament-engine/*":  ["../../packages/tournament-engine/src/*.ts"]
    }
  },
  "references": [
    { "path": "../../packages/db" },
    { "path": "../../packages/shared" },
    { "path": "../../packages/socket-types" },
    { "path": "../../packages/logger" },
    { "path": "../../packages/game-state" },
    { "path": "../../packages/token-service" },
    { "path": "../../packages/tournament-engine" }
  ],
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "src/types/**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}