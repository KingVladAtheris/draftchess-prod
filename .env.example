# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://draftchess:yourpassword@localhost:6432/draftchess?pgbouncer=true"
DATABASE_DIRECT_URL="postgresql://draftchess:yourpassword@localhost:5432/draftchess"

# ─── Postgres (docker-compose only) ────────────────────────────────────────────
POSTGRES_USER=draftchess
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=draftchess

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://:yourredispassword@localhost:6379"
REDIS_PASSWORD=yourredispassword

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Main app auth secret
AUTH_SECRET=your-auth-secret-here

# Admin-specific auth (used for /admin routes)
ADMIN_AUTH_SECRET=your-admin-auth-secret-here
ADMIN_JWT_SECRET=your-admin-jwt-secret-here

# NextAuth configuration (used by both main + admin)
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# ─── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ─── Internal Services ─────────────────────────────────────────────────────────
SOCKET_SERVER_URL=http://socket-server:3001
SOCKET_PORT=3001
HEALTH_PORT=3002

# ─── General ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production

# ─── Stripe (placeholder) ──────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...