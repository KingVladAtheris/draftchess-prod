# ─── Database ──────────────────────────────────────────────────────────────────
# Pooled connection — used by the app at runtime (through PgBouncer).
# In dev: points to PgBouncer on port 6432.
# On Railway: use the pooled connection string Railway provides.
DATABASE_URL="postgresql://draftchess:yourpassword@localhost:6432/draftchess?pgbouncer=true&connection_limit=1"

# Direct connection — used only by Prisma migrations (prisma migrate, prisma db push).
# Bypasses PgBouncer. Never used by the app at runtime.
# In dev: points to Postgres directly on port 5432.
# On Railway: use the direct/private connection string Railway provides.
DATABASE_DIRECT_URL="postgresql://draftchess:yourpassword@localhost:5432/draftchess"

# ─── Postgres (docker-compose only) ────────────────────────────────────────────
POSTGRES_USER=draftchess
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=draftchess

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://:yourredispassword@localhost:6379"
REDIS_PASSWORD=yourredispassword

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here
AUTH_URL=http://localhost:3000

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ─── Admin JWT Secret ─────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=your-admin-jwt-secret-here

# ─── Socket server ─────────────────────────────────────────────────────────────
SOCKET_PORT=3001

# ─── Matchmaker ────────────────────────────────────────────────────────────────
HEALTH_PORT=3002

LOG_LEVEL=info
NODE_ENV=production

# ─── Stripe (placeholder — not active until post-launch) ───────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
