{
  "$schema": "schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"]
    },
    "dev": {
      "cache":      false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs":   []
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs":   []
    },
    "clean": {
      "cache": false
    }
  }
}